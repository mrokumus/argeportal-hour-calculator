{
  "name": "pdks-extension",
  "version": "1.3.1",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "test": "jest",
    "icons": "node icons/generate.js",
    "typecheck": "wxt prepare && tsc --noEmit",
    "sign:firefox": "wxt build -b firefox && web-ext sign --source-dir .output/firefox-mv2 --artifacts-dir web-ext-artifacts --api-key=$AMO_KEY --api-secret=$AMO_SECRET --channel=unlisted"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.1.40",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "jest": "^29.7.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "web-ext": "^10.1.0",
    "wxt": "^0.20.25"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
