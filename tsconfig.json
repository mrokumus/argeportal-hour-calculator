{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["chrome", "jest"]
  },
  "include": ["src/**/*", "tests/**/*", "wxt.config.ts"],
  "exclude": ["node_modules", ".output", ".wxt"]
}
